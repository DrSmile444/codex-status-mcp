{
  "name": "codex-status-mcp",
  "version": "0.3.8",
  "description": "MCP server for retrieving Codex ChatGPT usage and rate-limit status.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./mcp": "./dist/mcp.js"
  },
  "bin": {
    "codex-status-mcp": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts --mcp",
    "prepack": "npm run build",
    "start": "node dist/cli.js --mcp",
    "status": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "codex",
    "openai",
    "mcp",
    "usage",
    "rate-limit"
  ],
  "author": "Dmytro Vakulenko",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DrSmile444/codex-status-mcp.git"
  },
  "homepage": "https://github.com/DrSmile444/codex-status-mcp#readme",
  "bugs": {
    "url": "https://github.com/DrSmile444/codex-status-mcp/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.19",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
