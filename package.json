{
  "name": "codex-status-mcp",
  "version": "0.1.0",
  "description": "MCP server for retrieving Codex ChatGPT usage and rate-limit status.",
  "type": "module",
  "bin": {
    "codex-status-mcp": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "prepack": "npm run build",
    "start": "node dist/cli.js",
    "status": "tsx src/cli.ts --once",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "codex",
    "openai",
    "mcp",
    "usage",
    "rate-limit"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.19",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "author": ""
}
